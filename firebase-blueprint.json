{
  "entities": {
    "Application": {
      "title": "Job Application",
      "description": "A job application being tracked by the user.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string", "description": "Name of the company." },
        "jobTitle": { "type": "string", "description": "Title of the job." },
        "seniorityLevel": { "type": "string", "description": "Seniority level (e.g., Senior, Lead)." },
        "location": { "type": "string", "description": "Job location." },
        "workMode": { "type": "string", "description": "Remote, Hybrid, or On-site." },
        "source": { "type": "string", "description": "Where the job was found." },
        "deadline": { "type": "string", "format": "date", "description": "Application deadline." },
        "dateApplied": { "type": "string", "format": "date", "description": "Date the application was submitted." },
        "status": { 
          "type": "string", 
          "enum": ["IDENTIFIED", "RESEARCHING", "APPLIED", "SCREENING", "INTERVIEW", "ASSESSMENT", "OFFER", "REJECTED", "ACCEPTED"],
          "description": "Current stage in the pipeline." 
        },
        "jobUrl": { "type": "string", "description": "URL to the job posting." },
        "cvVersion": { "type": "string", "description": "Reference to the CV version used." },
        "salaryRange": { "type": "string", "description": "Salary range listed." },
        "salaryExpectation": { "type": "string", "description": "User's target salary." },
        "recruiterName": { "type": "string", "description": "Name of the recruiter." },
        "internalConnection": { "type": "boolean", "description": "Whether an internal connection was found." },
        "referralSource": { "type": "string", "description": "Who referred the user." },
        "fitScore": { "type": "integer", "description": "User-defined fit score (1-5)." },
        "priorityTier": { "type": "string", "enum": ["A", "B", "C"], "description": "Priority tier (A=Dream, B=Strong, C=Backup)." },
        "nextAction": { "type": "string", "description": "The single most important next action." },
        "nextActionDate": { "type": "string", "format": "date", "description": "Due date for the next action." },
        "notes": { "type": "string", "description": "General notes about the application." },
        "uid": { "type": "string", "description": "The user ID of the owner." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the record was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the record was last updated." }
      },
      "required": ["companyName", "jobTitle", "status", "uid", "createdAt", "updatedAt"]
    },
    "CvData": {
      "title": "CV Data",
      "description": "The user's base CV data.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "location": { "type": "string" },
        "address": { "type": "string" },
        "summary": { "type": "string" },
        "experience": { "type": "array", "items": { "type": "object" } },
        "skills": { "type": "array", "items": { "type": "object" } },
        "education": { "type": "array", "items": { "type": "string" } },
        "certifications": { "type": "array", "items": { "type": "string" } },
        "uid": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "lastName", "uid", "updatedAt"]
    }
  },
  "firestore": {
    "applications": {
      "schema": "Application",
      "description": "Collection of job applications."
    },
    "cvs": {
      "schema": "CvData",
      "description": "Collection of user base CVs (one per user)."
    }
  }
}
